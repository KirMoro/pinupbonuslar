---
import { site, navLinks, isActivePath, type HeaderCta } from "../data/site";

interface Props {
  currentPath: string;
  cta?: HeaderCta;
}

const {
  currentPath,
  cta = {
    label: "Bonus al",
    href: site.visitPath,
    variant: "primary",
    rel: "sponsored nofollow"
  }
} = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href="/" aria-label="Pin Up ana səhifə">
      <img src="/assets/logo.svg" alt="Pin Up loqosu" width="120" height="40" />
    </a>
    <nav class="nav" aria-label="Əsas naviqasiya">
      {
        navLinks.map((link) => (
          <a class:list={{ active: isActivePath(currentPath, link.href) }} href={link.href}>
            {link.label}
          </a>
        ))
      }
    </nav>
    <a
      class:list={["btn", cta.variant === "secondary" && "secondary"]}
      href={cta.href}
      rel={cta.rel}
      aria-label={cta.ariaLabel}
    >
      {cta.label}
    </a>
  </div>
</header>
